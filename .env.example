# ============================================================
# ExpenseDesk AI — Environment Variables
# Date: 2026-07-10
# Copy this file to .env.local and fill in every value.
# NEVER commit .env.local to source control.
# ============================================================

# ------------------------------------------------------------
# DATABASE
# ------------------------------------------------------------
# Postgres connection string.
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public
DATABASE_URL="postgresql://postgres:password@localhost:5432/expensedesk?schema=public"

# ------------------------------------------------------------
# AUTH.JS (NextAuth v5)
# ------------------------------------------------------------
# Generate with: npx auth secret  (or: openssl rand -base64 32)
# Required in all environments.
AUTH_SECRET="replace-me-with-a-long-random-string-at-least-32-chars"

# Full base URL of your deployment (no trailing slash).
# Development: http://localhost:3000
# Production : https://expensedesk.yourdomain.com
AUTH_URL="http://localhost:3000"

# ------------------------------------------------------------
# GOOGLE OAUTH
# ------------------------------------------------------------
# 1. Go to https://console.cloud.google.com/apis/credentials
# 2. Create OAuth 2.0 Client ID (Web application)
# 3. Add Authorised redirect URI:
#      http://localhost:3000/api/auth/callback/google  (dev)
#      https://yourdomain.com/api/auth/callback/google (prod)
GOOGLE_CLIENT_ID="your-google-client-id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# ------------------------------------------------------------
# APPLICATION
# ------------------------------------------------------------
# Default currency code (ISO 4217). Used on new user creation.
NEXT_PUBLIC_DEFAULT_CURRENCY="INR"

# App name shown in emails and UI
NEXT_PUBLIC_APP_NAME="ExpenseDesk AI"

# ------------------------------------------------------------
# EMAIL (for verification / password reset — Phase 2)
# ------------------------------------------------------------
# Resend (https://resend.com) is recommended.
# RESEND_API_KEY="re_your_key"
# EMAIL_FROM="noreply@expensedesk.ai"

# ------------------------------------------------------------
# GEMINI AI (Google Gen AI)
# ------------------------------------------------------------
# Get your key at: https://aistudio.google.com/app/apikey
# Free tier: 1,500 requests/day on gemini-2.5-flash (as of July 2026)
GEMINI_API_KEY="AIza-your-gemini-api-key"

# Model override (optional). Defaults to gemini-2.5-flash.
# Options: gemini-2.5-flash | gemini-2.5-pro | gemini-2.0-flash
# GEMINI_MODEL="gemini-2.5-flash"
